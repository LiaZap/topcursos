# Copie para .env (local) ou configure no painel do EasyPanel (Environment).
# Estas variáveis são NEXT_PUBLIC_* — elas são embutidas no bundle no momento do
# `next build`, então precisam estar definidas ANTES do build (build args no Docker).

# Número de WhatsApp usado em todos os CTAs (somente dígitos, com DDI 55).
NEXT_PUBLIC_WHATSAPP=5551995622999

# URL do webhook (N8N) que recebe o POST do lead ao enviar o formulário.
# Deixe vazio para desativar o envio ao webhook (o fluxo do WhatsApp continua funcionando).
NEXT_PUBLIC_WEBHOOK_URL=
